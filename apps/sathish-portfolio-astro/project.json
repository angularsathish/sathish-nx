{
    "name": "sathish-portfolio-astro",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/sathish-portfolio-astro/src",
    "projectType": "application",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "astro build",
          "cwd": "apps/sathish-portfolio-astro"
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "astro dev",
          "cwd": "apps/sathish-portfolio-astro"
        }
      },
      "preview": {
        "executor": "nx:run-commands",
        "options": {
          "command": "astro preview",
          "cwd": "apps/sathish-portfolio-astro"
        }
      }
    },
    "tags": ["astro", "frontend"]
}