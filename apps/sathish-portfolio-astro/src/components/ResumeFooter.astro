---
// src/components/ResumeFooter.astro
---

<footer class="bg-gray-950 py-12 sm:py-16 relative">
  <!-- pattern -->
  <div class="absolute bg-hero opacity-[.03]"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-12 relative z-10">
    <div class="flex flex-col items-center text-center space-y-4 sm:space-y-6">
      <h3 class="flex items-center gap-2 sm:gap-3">
        <i class="fas fa-code text-green-400 text-2xl sm:text-3xl led-glow"></i>
        <span class="text-xl sm:text-2xl font-bold text-white font-mono">Sathish Kumar</span>
      </h3>
      <p class="text-sm sm:text-base text-gray-300 leading-relaxed max-w-2xl">
        Building the future with clean code, creativity, and a passion for innovation.
      </p>
      <div class="flex gap-4 sm:gap-5">
        <a href="https://github.com/angularsathish" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-green-400 text-lg sm:text-xl transition-colors transform hover:scale-110">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://www.linkedin.com/in/sathish-kumar-184aa962/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-green-400 text-lg sm:text-xl transition-colors transform hover:scale-110">
          <i class="fab fa-linkedin"></i>
        </a>
        <a href="#" class="text-gray-300 hover:text-green-400 text-lg sm:text-xl transition-colors transform hover:scale-110">
          <i class="fab fa-twitter"></i>
        </a>
        <a href="#" class="text-gray-300 hover:text-green-400 text-lg sm:text-xl transition-colors transform hover:scale-110">
          <i class="fab fa-dev"></i>
        </a>
      </div>
    </div>

    <div class="mt-8 sm:mt-10 lg:mt-12 pt-6 sm:pt-8 border-t border-gray-800 flex justify-center items-center">
      <p class="text-gray-300 text-xs sm:text-sm text-center">&copy; <span id="current-year"></span> Sathish Kumar. All rights reserved.</p>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const currentYear = document.getElementById('current-year');
    if (currentYear) {
      currentYear.textContent = new Date().getFullYear().toString();
    }
  });
</script>
