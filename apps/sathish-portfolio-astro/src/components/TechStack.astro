    <div class="flex items-center gap-2 text-gray-400"><i class="fab fa-nextjs text-2xl text-black-400">Next</i> Next.Js</div>
    <div class="flex items-center gap-2 text-gray-400"><i class="fab fa-astro text-2xl text-black-400">A</i> Astro</div>

    <div class="flex items-center gap-2 text-gray-400"><i class="fa-brands fa-tailwind-css text-2xl text-blue-600"></i> Tailwind</div>
