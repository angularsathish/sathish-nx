    <div class="flex items-center gap-2 text-gray-400"><i class="fab fa-git-alt text-2xl text-orange-600"></i> Git</div>
    <div class="flex items-center gap-2 text-gray-400"><i class="fas fa-database text-2xl text-blue-700"></i> Mysql</div>
    <div class="flex items-center gap-2 text-gray-400"><i class="fas fa-leaf text-2xl text-green-600"></i> MongoDB</div>
    <div class="flex items-center gap-2 text-gray-400"><i class="fas fa-firebase text-2xl text-green-600"></i> Firebase</div>
    
